# Copy to .env.local for secrets. Values in this file are committed non-secret defaults.
# NEXT_PUBLIC_* variables are exposed to the browser at build time.

# ── Required (fill in .env.local) ─────────────────────────────────────────
# Anthropic API key used by the wizard for resume identity extraction.
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ── Public defaults (already live in .env; override here only if needed) ──
# Google Sheets template the wizard offers users to duplicate.
# Must be shared "Anyone with the link: Viewer" for the duplicate-template flow to work.
NEXT_PUBLIC_TEMPLATE_SHEET_ID=1vifOnKWyAfLgdeqT48xGsSJALeQZAOcxlPpfRbT5xSI

# ── Optional: self-hosted telemetry ───────────────────────────────────────
# Override the maintainer's PostHog project with your own fork's analytics.
# Leave blank to inherit the default in lib/generateConfig.ts.
# NEXT_PUBLIC_POSTHOG_KEY=phc_...
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
